# Copy this file to .env and fill in real values. Never commit .env itself
# (it's already covered by .gitignore).

# Required. API key for Groq's LLM inference API, used by rag/llm.py.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional. Used by streamlit_app.py to locate the FastAPI backend's /ask
# endpoint. Defaults to http://127.0.0.1:9000/ask if unset (matches the
# uvicorn port used in the README/Docker setup below).
RAG_API_URL=http://127.0.0.1:9000/ask
